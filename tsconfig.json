{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "lib": ["ES2022", "ESNext"],
    "outDir": "./",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["**/*.mts", "**/*.cts", "**/*.ts"],
  "exclude": ["node_modules", "test", "**/*.d.ts", "**/*.d.mts", "**/*.d.cts", "**/test.*"]
}