{
  "name": "nexfpack",
  "version": "0.1.2",
  "description": "A tool for building single executable files from Node.js scripts or modules.",
  "license": "MIT",
  "repository": "https://github.com/nexfteam/Nexfpack",
  "bugs": {
    "url": "https://github.com/nexfteam/Nexfpack/issues"
  },
  "homepage": "https://github.com/nexfteam/Nexfpack#readme",
  "author": "nexfteam",
  "type": "module",
  "types": "index.d.mts",
  "main": "index.cjs",
  "module": "index.mjs",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.cjs"
    }
  },
  "bin": {
    "nexfpack": "cli.mjs"
  },
  "files": [
    "index.cjs",
    "index.mjs",
    "cli.mjs",
    "README.md",
    "README-CN.md",
    "LICENSE",
    "index.d.mts",
    "index.d.cts"
  ],
  "scripts": {
    "compile": "tsc"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "copyfiles": "^2.4.1",
    "modern-tar": "^0.7.6",
    "postject": "1.0.0-alpha.6"
  },
  "devDependencies": {
    "@types/copyfiles": "^2.4.4",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "build",
    "builder",
    "single-executable",
    "SEA",
    "native",
    "module",
    "pkg",
    "dll",
    "packaging",
    "node",
    "postject",
    "ESM",
    "CommonJS"
  ]
}
